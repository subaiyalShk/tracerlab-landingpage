# ── Voice CTA (embedded Retell voice agent + Cal.com booking) ─────────────────
# Copy to .env.local for dev; set the same in Vercel for prod/preview.
# Until RETELL_API_KEY + RETELL_AGENT_ID are set, the CTA shows the "Book a call" fallback.

# Retell — server only (never expose; no NEXT_PUBLIC_ prefix)
RETELL_API_KEY=
RETELL_AGENT_ID=            # printed by: node scripts/provision-retell-agent.mjs
# RETELL_VOICE_ID=11labs-Adrian   # optional override used by the provision script

# Shared secret baked into the book_call tool URL (?s=...) and checked by /api/book
RETELL_FUNCTION_SECRET=

# Cal.com — server only. Shared with the Tracerlabs sales-dashboard account.
CAL_API_KEY=               # cal_live_… from Cal.com Settings → Developer → API Keys
# Identify the event type ONE way (team event used by the dashboard's discovery call):
CAL_EVENT_TYPE_SLUG=discovery-call
CAL_TEAM_SLUG=tracerlabs
# CAL_USERNAME=            # alt to team: slug + personal username
# CAL_EVENT_TYPE_ID=       # alt: numeric event-type id (takes precedence if set)

# Public Cal.com scheduling link — used by the "Book a call" fallback button
NEXT_PUBLIC_CAL_BOOKING_LINK=https://cal.com/team/tracerlabs/discovery-call

# Public base URL Retell uses to call /api/book (a Vercel preview/prod URL, NOT localhost).
# Only needed when running the provision script.
SITE_URL=
